%% ============================================================
%% Raccoglitore del Camminatore — Sentiero Italia CAI
%% Documento A6 sequenziale (105 x 148 mm), 4 facciate logiche.
%% L'imposizione 2x1 su A5 landscape fronte/retro è gestita a
%% valle dallo script Python (pypdf) — come il passaporto
%% Valle d'Aosta. Ordine pagine:
%%   1 copertina · 2 presentazione · 3 cos'è il SICAI · 4 mappa
%% ============================================================
\documentclass[10pt]{article}
\usepackage[paperwidth=105mm, paperheight=148mm, margin=0pt]{geometry}
\usepackage{fontspec}
\usepackage{xcolor}
\usepackage{graphicx}
\usepackage{tikz}
\usetikzlibrary{positioning,calc}
\usepackage{microtype}
\pagestyle{empty}
\setlength{\parindent}{0pt}

% niente sillabazione in tutto il raccoglitore (testi brevi, giustificati):
% impostazione globale, le assegnazioni dentro i nodi TikZ non sono affidabili
\hyphenpenalty=10000
\exhyphenpenalty=10000
\tolerance=9999
\emergencystretch=3em

% ---- Colori ----
\definecolor{caiblu}{HTML}{1B3569}
\definecolor{cailogoblu}{HTML}{0A4484}
\definecolor{caiblulight}{HTML}{7A9CC5}
\definecolor{bianco}{HTML}{FFFFFF}
\definecolor{grigiochiarotesto}{HTML}{6B6B6B}
\definecolor{grigiolinea}{HTML}{CCCCCC}
\definecolor{testoprimario}{HTML}{2B2B2B}

% ---- Font ----
\setmainfont{Montserrat}[
  Path           = ((( font_path ))),
  UprightFont    = *-Regular,
  BoldFont       = *-Bold,
  ItalicFont     = *-Italic,
  BoldItalicFont = *-BoldItalic,
]

% testi secondari su sfondo blu: bianco pieno, grassetto
\newcommand{\testofooter}[1]{%
  {\bfseries\fontsize{7}{9}\selectfont\color{bianco}#1}}
\newcommand{\creditolinea}[1]{%
  {\bfseries\fontsize{7}{8.5}\selectfont\color{bianco}\mbox{#1}}}

% ---- Header pagine interne ----
% #1 = titolo sezione (es. "Presentazione")
\newcommand{\pageheader}[1]{%
  \fill[caiblu] (0,0) rectangle (105mm,-14mm);
  \node[anchor=west, text=bianco, inner sep=0pt]
    at (5mm,-7mm) {\fontsize{9}{11}\selectfont\bfseries #1};
  \node[anchor=east, text=bianco, inner sep=0pt]
    at (100mm,-7mm) {\fontsize{7}{9}\selectfont\bfseries Sentiero Italia CAI};
}

\begin{document}

