%% ── PAGINA 3: COS'È IL SICAI (interno destra) ───────────────
\newpage
\begin{tikzpicture}[remember picture, overlay, shift={(current page.north west)}]
  \pageheader{Cos'è il SICAI}

  % sfondo blu sotto l'header
  \fill[caiblu] (0,-14mm) rectangle (105mm,-148mm);

  % testo descrittivo (2 paragrafi), centrato nella fascia header–badge.
  % Paragrafi separati con \par (non \\: pgf rielabora ogni riga e
  % resetta font e penalty — v. README nota 7); niente sillabazione.
  \node[anchor=center, align=justify, text=bianco, inner sep=0pt,
        text width=93mm, font=\fontsize{8}{9.5}\selectfont]
    at (52.5mm,-58.5mm)
    {Il Sentiero Italia rappresenta uno dei progetti più ambiziosi ed affascinanti nel panorama dell'escursionismo italiano. Attraversa l'intera Penisola, abbracciandone montagne e valli, coste e pianure, città d'arte e piccoli borghi. Questa straordinaria avventura è nata grazie al supporto delle sezioni del Club Alpino Italiano, istituzione storica che da oltre un secolo promuove la cultura montana e la tutela dell'ambiente alpino ed appenninico.\par\vspace{2.5mm}
     Sentiero Italia è un progetto partecipato, attorno a cui far convergere iniziative di sviluppo economico delle terre alte italiane, promuovendo in maniera nuova e viva tradizioni, specialità artigianali e naturalistiche, e proponendo una nuova cultura, trasversale e condivisa.};

  % colonna Android: badge store + QR
  \node[anchor=south, inner sep=0pt] (qrandroid) at (26mm,-143mm)
    {\includegraphics[width=26mm]{((( qr_android_path )))}};
  \node[anchor=south, inner sep=0pt] at (26mm,-115mm)
    {\includegraphics[width=28mm]{((( asset_path )))android.png}};

  % colonna iOS: badge store + QR
  \node[anchor=south, inner sep=0pt] (qrios) at (79mm,-143mm)
    {\includegraphics[width=26mm]{((( qr_ios_path )))}};
  \node[anchor=south, inner sep=0pt] at (79mm,-115mm)
    {\includegraphics[width=28mm]{((( asset_path )))appstore.png}};
\end{tikzpicture}

