%% ============================================================
%% Passaporto del Camminatore — Sentiero Italia CAI
%% Documento A6 sequenziale (105 x 148 mm).
%% L'imposizione 2x2 su A4 fronte/retro è gestita a valle
%% dallo script Python (pypdf) — design e imposizione separati.
%% ============================================================
\documentclass[10pt]{article}
\usepackage[paperwidth=105mm, paperheight=148mm, margin=0pt]{geometry}
\usepackage{fontspec}
\usepackage{xcolor}
\usepackage{graphicx}
\usepackage{tikz}
\usetikzlibrary{positioning}
\usepackage{microtype}
\usepackage{truncate}
\pagestyle{empty}
\setlength{\parindent}{0pt}

% ---- Colori ----
\definecolor{caiblu}{HTML}{1B3569}
\definecolor{cailogoblu}{HTML}{0A4484}
\definecolor{caiblulight}{HTML}{7A9CC5}
\definecolor{bianco}{HTML}{FFFFFF}
\definecolor{grigiochiarotesto}{HTML}{6B6B6B}
\definecolor{grigiolinea}{HTML}{CCCCCC}
\definecolor{testoprimario}{HTML}{2B2B2B}

% ---- Font ----
\setmainfont{Montserrat}[
  Path           = ((( font_path ))),
  UprightFont    = *-Regular,
  BoldFont       = *-Bold,
  ItalicFont     = *-Italic,
  BoldItalicFont = *-BoldItalic,
]

% ---- Header pagine interne (timbri / note) ----
% #1 = etichetta destra (es. "Tappe 1–12" oppure "Note")
\newcommand{\pageheader}[1]{%
  \fill[caiblu] (0,0) rectangle (105mm,-14mm);
  \node[anchor=west, text=bianco, inner sep=0pt]
    at (5mm,-7mm) {\fontsize{9}{11}\selectfont\bfseries ((( gruppo_nome )))};
  \node[anchor=center, text=bianco, opacity=0.55, inner sep=0pt]
    at (52.5mm,-7mm) {\fontsize{7}{9}\selectfont Sentiero Italia CAI};
  \node[anchor=east, text=bianco, opacity=0.70, inner sep=0pt]
    at (100mm,-7mm) {\fontsize{8}{10}\selectfont #1};
}

\begin{document}

%% ── PAGINA 1: COPERTINA ─────────────────────────────────────
\begin{tikzpicture}[remember picture, overlay, shift={(current page.north west)}]
  % sfondo pieno
  \fill[caiblu] (0,0) rectangle (105mm,-148mm);

  % loghi affiancati, blocco allineato a destra (bordo dx a 99mm), top 14mm
  % sinistra: CAI — destra: SICAI
  \node[anchor=north east, inner sep=0pt] (logosi) at (99mm,-14mm)
    {\includegraphics[height=16mm]{((( asset_path )))logo_sicai.png}};
  \node[anchor=north east, inner sep=0pt] at ([xshift=-6mm]logosi.north west)
    {\includegraphics[height=16mm]{((( asset_path )))logo_cai.png}};

  % box PASSAPORTO (7mm sotto i loghi: -14 -16 -7 = -37mm)
  \fill[bianco, rounded corners=2mm] (49mm,-37mm) rectangle (99mm,-47mm);
  \node[anchor=center, text=caiblu, inner sep=0pt] at (74mm,-42mm)
    {\fontsize{11}{13}\selectfont\bfseries PASSAPORTO};

  % titolo (5mm sotto il box)
  \node[anchor=north east, align=right, text=bianco, inner sep=0pt,
        font=\fontsize{17}{18.7}\selectfont\bfseries]
    at (99mm,-52mm)
    {SENTIERO\\ITALIA CAI};

  % nome del gruppo (5mm sotto il titolo)
  \node[anchor=north east, align=right, text=bianco, inner sep=0pt]
    at (99mm,-70.5mm)
    {\fontsize{12}{15}\selectfont\bfseries ((( gruppo_nome )))};

  % statistiche aggregate per regione (tappe, km, dislivelli)
  ((* for stat in statistiche_regioni *))
  \node[anchor=north east, align=right, text=bianco, inner sep=0pt,
        font=\fontsize{6}{7.5}\selectfont]
    at (99mm, {-78mm - ((( loop.index0 * 7 )))mm})
    {((* if regioni_nome *)){\bfseries ((( stat.regione )))}\\((* endif *))
     {\color{caiblulight}((( stat.tappe ))) tappe~·~((( stat.km ))) km~·~+((( stat.dislivello ))) m~/~--((( stat.discesa ))) m}};
  ((* endfor *))

  % url in basso a sinistra
  \node[anchor=south west, text=bianco, opacity=0.60, inner sep=0pt]
    at (6mm,-143mm)
    {\fontsize{7}{9}\selectfont www.sentieroitalia.cai.it};
\end{tikzpicture}

%% ── PAGINE TIMBRI ───────────────────────────────────────────
((* for pagina in pagine_timbri *))
\newpage
\begin{tikzpicture}[remember picture, overlay, shift={(current page.north west)}]
  \pageheader{Tappe ((( pagina.ref_da )))--((( pagina.ref_a )))}

  % griglia 3x4 (12 celle da 35 x 33.5 mm) sotto l'header da 14 mm
  ((* for cella in pagina.celle *))
  ((* set cx = (loop.index0 % 3) * 35 *))
  ((* set cy = 14 + (loop.index0 // 3) * 33.5 *))
  ((* if cella.tappa *))
  % bordo cella
  \draw[grigiolinea, line width=0.4pt]
    ({((( cx )))mm}, {-((( cy )))mm}) rectangle ++(35mm,-33.5mm);
  % ref tappa — alto sinistra
  \node[anchor=north west, inner sep=0pt]
    at ({((( cx )))mm + 2mm}, {-((( cy )))mm - 1.5mm})
    {\fontsize{7}{8}\selectfont\bfseries\color{caiblu}{((( cella.tappa.ref )))}};
  % regione — alto destra, font più piccolo
  \node[anchor=north east, inner sep=0pt, text width=20mm, align=right, opacity=0.85]
    at ({((( cx )))mm + 33mm}, {-((( cy )))mm - 1.5mm})
    {\fontsize{4}{4.8}\selectfont\color{caiblu}{((( cella.tappa.regione )))}};
  % zona timbro tratteggiata quadrata, centrata sotto il ref
  \draw[grigiolinea, line width=0.5pt, dashed]
    ({((( cx )))mm + 4.5mm}, {-((( cy )))mm - 6mm}) rectangle ++(26mm,-26mm);
  % info tappa dentro il riquadro timbro (centrata in altezza, testo a capo)
  \node[anchor=center, inner sep=0pt, text width=24mm, align=left]
    at ({((( cx )))mm + 17.5mm}, {-((( cy )))mm - 19mm})
    {\fontsize{4}{4.8}\selectfont\color{testoprimario}\raggedright
     ((* if cella.tappa.da *))
     {\bfseries\color{caiblu}Inizio:} ((( cella.tappa.da )))\\[0.3mm]
     ((* endif *))
     ((* if cella.tappa.a *))
     {\bfseries\color{caiblu}Arrivo:} ((( cella.tappa.a )))\\[0.3mm]
     ((* endif *))
     {\bfseries\color{caiblu}Km:} ((( cella.tappa.km )))\\[0.3mm]
     ((* if cella.tappa.dislivello *))
     {\bfseries\color{caiblu}Dislivello positivo:} ((( cella.tappa.dislivello ))) m\\[0.3mm]
     ((* endif *))
     ((* if cella.tappa.discesa *))
     {\bfseries\color{caiblu}Dislivello negativo:} ((( cella.tappa.discesa ))) m
     ((* endif *))
    };
  ((* endif *))
  ((* endfor *))
\end{tikzpicture}
((* endfor *))

%% ── PAGINE NOTE (riempimento fino a multiplo di 4) ──────────
((* for _ in range(pagine_note) *))
\newpage
\begin{tikzpicture}[remember picture, overlay, shift={(current page.north west)}]
  \pageheader{Note}
  \foreach \i in {1,...,14} {
    \draw[grigiolinea, line width=0.3pt]
      (6mm, -14mm - 8mm - \i*8mm) -- (99mm, -14mm - 8mm - \i*8mm);
  }
\end{tikzpicture}
((* endfor *))

\end{document}
