%% ============================================================
%% Passaporto del Camminatore — Sentiero Italia CAI
%% Documento A6 sequenziale (105 x 148 mm).
%% L'imposizione 2x2 su A4 fronte/retro è gestita a valle
%% dallo script Python (pypdf) — design e imposizione separati.
%% ============================================================
\documentclass[10pt]{article}
\usepackage[paperwidth=105mm, paperheight=148mm, margin=0pt]{geometry}
\usepackage{fontspec}
\usepackage{xcolor}
\usepackage{graphicx}
\usepackage{tikz}
\usetikzlibrary{positioning}
\usepackage{microtype}
\usepackage{truncate}
\pagestyle{empty}
\setlength{\parindent}{0pt}

% riga a larghezza massima: scala SOLO in riduzione (a differenza di \resizebox
% che ingrandirebbe anche i testi più corti della larghezza richiesta)
\newsavebox{\fitbox}
\newcommand{\fitwidth}[2]{%
  \sbox{\fitbox}{#2}%
  \ifdim\wd\fitbox>#1\relax\resizebox{#1}{!}{\usebox{\fitbox}}\else\usebox{\fitbox}\fi}

% ---- Colori ----
\definecolor{caiblu}{HTML}{1B3569}
\definecolor{cailogoblu}{HTML}{0A4484}
\definecolor{caiblulight}{HTML}{7A9CC5}
\definecolor{bianco}{HTML}{FFFFFF}
\definecolor{grigiochiarotesto}{HTML}{6B6B6B}
\definecolor{grigiolinea}{HTML}{CCCCCC}
\definecolor{testoprimario}{HTML}{2B2B2B}

% ---- Font ----
\setmainfont{Montserrat}[
  Path           = ((( font_path ))),
  UprightFont    = *-Regular,
  BoldFont       = *-Bold,
  ItalicFont     = *-Italic,
  BoldItalicFont = *-BoldItalic,
]

% testi secondari su sfondo blu: bianco pieno, grassetto
\newcommand{\testofooter}[1]{%
  {\bfseries\fontsize{7}{9}\selectfont\color{bianco}#1}}
\newcommand{\creditolinea}[1]{%
  {\bfseries\fontsize{7}{8.5}\selectfont\color{bianco}\mbox{#1}}}

% ---- Header pagine interne (timbri / note) ----
% #1 = etichetta destra (es. "Tappe 1–12" oppure "Note")
% #2 = numerazione (es. "Pag. 1 di 7", senza copertina)
\newcommand{\pageheader}[2]{%
  \fill[caiblu] (0,0) rectangle (105mm,-14mm);
  \node[anchor=west, text=bianco, inner sep=0pt]
    at (5mm,-7mm) {\fontsize{9}{11}\selectfont\bfseries ((( gruppo_nome )))};
  \node[anchor=center, text=bianco, inner sep=0pt]
    at (52.5mm,-7mm) {\fontsize{7}{9}\selectfont\bfseries Sentiero Italia CAI};
  \node[anchor=east, align=right, text=bianco, inner sep=0pt]
    at (100mm,-7mm) {%
      \shortstack[r]{%
        {\fontsize{8}{10}\selectfont\bfseries #1}\\[0.2mm]
        {\fontsize{6}{7.5}\selectfont\bfseries #2}}};
}

\begin{document}

%% ── PAGINA 1: COPERTINA ─────────────────────────────────────
\begin{tikzpicture}[remember picture, overlay, shift={(current page.north west)}]
  % sfondo pieno
  \fill[caiblu] (0,0) rectangle (105mm,-148mm);

  % mappa regione/i (40 x 50 mm, in alto a sinistra) — generata a
  % build-time da genera_mappe.py (tile Webmapp + overlay SICAI)
  \begin{scope}
    \clip[rounded corners=2mm] (6mm,-14mm) rectangle (46mm,-64mm);
    \node[anchor=north west, inner sep=0pt] at (6mm,-14mm)
      {\includegraphics[width=40mm, height=50mm]{((( mappa_path )))}};
  \end{scope}
  \draw[caiblulight, line width=0.5pt, rounded corners=2mm]
    (6mm,-14mm) rectangle (46mm,-64mm);
  % credito cartografico (sotto la mappa, stesso stile dei crediti foto)
  \draw[caiblulight, opacity=0.4, line width=0.3pt]
    (6mm,-64.5mm) -- (46mm,-64.5mm);
  \node[anchor=north east, align=right, inner sep=0pt]
    at (46mm,-65mm)
    {\creditolinea{((( mappa_credit )))}};

  % loghi affiancati, blocco allineato a destra (bordo dx a 99mm), top 14mm
  % sinistra: CAI — destra: SICAI
  \node[anchor=north east, inner sep=0pt] (logosi) at (99mm,-14mm)
    {\includegraphics[height=16mm]{((( asset_path )))logo_sicai.png}};
  \node[anchor=north east, inner sep=0pt] at ([xshift=-6mm]logosi.north west)
    {\includegraphics[height=16mm]{((( asset_path )))logo_cai.png}};

  % box PASSAPORTO (sotto i loghi, colonna destra — 50 mm, allineato al titolo)
  \fill[bianco, rounded corners=2mm] (49mm,-34mm) rectangle (99mm,-43mm);
  \node[anchor=center, text=caiblu, inner sep=0pt] at (74mm,-38.5mm)
    {\fontsize{10}{12}\selectfont\bfseries PASSAPORTO};

  % titolo su una riga unica, stessa larghezza del box (50 mm)
  \node[anchor=north east, inner sep=0pt, text=bianco]
    at (99mm,-47mm)
    {\resizebox{50mm}{!}{\bfseries SENTIERO ITALIA CAI}};

  % nome del gruppo (sotto il titolo)
  \node[anchor=north east, align=right, text=bianco, inner sep=0pt]
    at (99mm,-54mm)
    {\fontsize{12}{15}\selectfont\bfseries ((( gruppo_nome )))};

  % riga 2: elenco regioni su riga unica (solo multiregione; nei monoregione
  % regioni_lista è vuoto e il nodo non viene emesso)
  ((* if regioni_lista *))
  \node[anchor=north east, inner sep=0pt, text=bianco]
    at (99mm,-59.5mm)
    {\fitwidth{50mm}{\fontsize{7}{8.5}\selectfont\bfseries ((( regioni_lista )))}};
  ((* endif *))

  % recap UNICO aggregato del gruppo: riga 3 nei multiregione, riga 2 (subito
  % dopo il nome, al posto dell'elenco regioni) nei monoregione. Il blocco testo
  % risale così che il suo fondo si allinei col fondo della mappa a sinistra.
  ((* set recap_y_mm = 63 if regioni_lista else 59.5 *))
  \node[anchor=north east, inner sep=0pt, text=bianco]
    at (99mm,-((( recap_y_mm )))mm)
    {\fitwidth{50mm}{\fontsize{7.5}{9}\selectfont\bfseries
      ((( statistiche_totali.tappe ))) tappe~·~((( statistiche_totali.km ))) km~·~D+ ((( statistiche_totali.dislivello ))) m~/~D- ((( statistiche_totali.discesa ))) m}};

  % foto copertina — slot dinamico sopra la fascia credito
  \begin{scope}
    \clip[rounded corners=2mm]
      (6mm, -((( placeholder_top_mm )))mm) rectangle (99mm,-((( placeholder_image_bottom_mm )))mm);
    \node[anchor=north west, inner sep=0pt] at (6mm,-((( placeholder_top_mm )))mm)
      {\includegraphics[width=93mm, height=((( placeholder_image_height_mm )))mm, keepaspectratio=false]{((( copertina_path )))}};
  \end{scope}
  % credito fotografico: 2 righe, stessa dimensione ADATTATA alla larghezza foto
  % (93 mm) — NON segue la dimensione del credito mappa. Riga 2 da
  % "Sentiero Italia CAI". La size si riduce quanto basta per stare in 2 righe.
  \draw[caiblulight, opacity=0.4, line width=0.3pt]
    (6mm,-((( copertina_credit_line_mm )))mm) -- (99mm,-((( copertina_credit_line_mm )))mm);
  \node[anchor=north east, align=right, inner sep=0pt]
    at (99mm,-((( copertina_credit_text_mm )))mm)
    {\resizebox{93mm}{!}{%
      \shortstack[r]{%
        {\creditolinea{((( copertina_credit_line1 )))}}\\[0.3mm]
        {\creditolinea{((( copertina_credit_line2 )))}}%
      }}};

  % url in basso a sinistra
  \node[anchor=south west, inner sep=0pt]
    at (6mm,-143mm)
    {\testofooter{www.sentieroitalia.cai.it}};
\end{tikzpicture}

%% ── PAGINE TIMBRI ───────────────────────────────────────────
((* for pagina in pagine_timbri *))
\newpage
\begin{tikzpicture}[remember picture, overlay, shift={(current page.north west)}]
  \pageheader{Tappe ((( pagina.ref_da )))--((( pagina.ref_a )))}{Pag. ((( loop.index ))) di ((( pagine_numerate )))}

  % griglia 3x4 (12 celle da 35 x 33.5 mm) sotto l'header da 14 mm
  ((* for cella in pagina.celle *))
  ((* set cx = (loop.index0 % 3) * 35 *))
  ((* set cy = 14 + (loop.index0 // 3) * 33.5 *))
  ((* if cella.tappa *))
  % bordo cella
  \draw[grigiolinea, line width=0.4pt]
    ({((( cx )))mm}, {-((( cy )))mm}) rectangle ++(35mm,-33.5mm);
  % filigrana tracciato tappa (centrata nel riquadro timbro 26x26 mm)
  ((* if cella.tappa.tracciato_path *))
  \node[anchor=center, inner sep=0pt, opacity=0.2]
    at ({((( cx )))mm + 17.5mm}, {-((( cy )))mm - 19mm})
    {\includegraphics[height=24mm]{((( cella.tappa.tracciato_path )))}};
  ((* endif *))
  % ref tappa — alto sinistra
  \node[anchor=north west, inner sep=0pt]
    at ({((( cx )))mm + 2mm}, {-((( cy )))mm - 1.5mm})
    {\fontsize{7}{8}\selectfont\bfseries\color{caiblu}{((( cella.tappa.ref )))}};
  % regione — alto destra, font più piccolo (una riga, scala in riduzione)
  \node[anchor=north east, inner sep=0pt, opacity=0.85]
    at ({((( cx )))mm + 33mm}, {-((( cy )))mm - 1.5mm})
    {\fitwidth{18mm}{\mbox{\fontsize{4}{4.8}\selectfont\bfseries\color{caiblu}{((( cella.tappa.regione )))}}}};
  % zona timbro tratteggiata quadrata, centrata sotto il ref
  \draw[grigiolinea, line width=0.5pt, dashed]
    ({((( cx )))mm + 4.5mm}, {-((( cy )))mm - 6mm}) rectangle ++(26mm,-26mm);
  % info tappa: riempie il riquadro timbro, font adattivo uniforme nella cella
  ((* set lda = (cella.tappa.da|length) if cella.tappa.da else 0 *))
  ((* set la = (cella.tappa.a|length) if cella.tappa.a else 0 *))
  ((* set lab = lda + la *))
  ((* if lab <= 22 *))((* set fs = 8 *))((* set bs = 9.6 *))
  ((* elif lab <= 38 *))((* set fs = 7 *))((* set bs = 8.4 *))
  ((* elif lab <= 60 *))((* set fs = 6 *))((* set bs = 7.2 *))
  ((* elif lab <= 95 *))((* set fs = 5.5 *))((* set bs = 6.6 *))
  ((* else *))((* set fs = 5 *))((* set bs = 6 *))((* endif *))
  \node[anchor=center, inner sep=0pt, text width=24mm, align=center]
    at ({((( cx )))mm + 17.5mm}, {-((( cy )))mm - 19mm})
    {\fontsize{((( fs )))}{((( bs )))}\selectfont\color{testoprimario}
     ((* if cella.tappa.da *)){\bfseries\color{caiblu}Da }((( cella.tappa.da ))) ((* endif *))%
     ((* if cella.tappa.a *)){\bfseries\color{caiblu}a }((( cella.tappa.a )))((* endif *))%
     ((* if cella.tappa.da or cella.tappa.a *))\\[0.35mm]((* endif *))
     \shortstack[c]{%
       \mbox{{\bfseries\color{caiblu}Km }((( cella.tappa.km )))}%
       ((* if cella.tappa.dislivello *))\\[0.35mm]\mbox{{\bfseries\color{caiblu}D+ }((( cella.tappa.dislivello )))~m}((* endif *))%
       ((* if cella.tappa.discesa *))\\[0.35mm]\mbox{{\bfseries\color{caiblu}D- }((( cella.tappa.discesa )))~m}((* endif *))%
     }%
    };
  ((* endif *))
  ((* endfor *))
\end{tikzpicture}
((* endfor *))

%% ── PAGINE NOTE (riempimento fino a multiplo di 4) ──────────
((* for _ in range(pagine_note) *))
((* set pagina_num = pagine_timbri|length + loop.index *))
\newpage
\begin{tikzpicture}[remember picture, overlay, shift={(current page.north west)}]
  % filigrana logo CAI (centrata su A6, dietro header e righe)
  \node[anchor=center, inner sep=0pt, opacity=0.2] at (52.5mm,-74mm)
    {\includegraphics[height=48mm]{((( asset_path )))logo_cai.png}};
  \pageheader{Note}{Pag. ((( pagina_num ))) di ((( pagine_numerate )))}
  \foreach \i in {1,...,14} {
    \draw[grigiolinea, line width=0.3pt]
      (6mm, -14mm - 8mm - \i*8mm) -- (99mm, -14mm - 8mm - \i*8mm);
  }
\end{tikzpicture}
((* endfor *))

