%% ── PAGINE TIMBRI ───────────────────────────────────────────
((* for pagina in pagine_timbri *))
\newpage
\begin{tikzpicture}[remember picture, overlay, shift={(current page.north west)}]
  \pageheader{Tappe ((( pagina.ref_da )))--((( pagina.ref_a )))}

  % griglia 3x2 (celle 35 x 67 mm) sotto l'header
  ((* for cella in pagina.celle *))
  ((* set cx = (loop.index0 % 3) * 35 *))
  ((* set cy = 14 + (loop.index0 // 3) * 67 *))
  ((* if cella.tappa *))
  % bordo cella
  \draw[grigiolinea, line width=0.4pt]
    ({((( cx )))mm}, {-((( cy )))mm}) rectangle ++(35mm,-67mm);
  % zona timbro tratteggiata (ampliata: la zona info contiene solo numero e ref)
  \draw[grigiolinea, line width=0.5pt, dashed]
    ({((( cx )))mm + 3mm}, {-((( cy )))mm - 12mm}) rectangle ++(29mm,-52mm);
  % zona info tappa: solo il ref/nome della tappa, nel colore dell'header
  \node[anchor=north west, inner sep=0pt, text width=29mm]
    at ({((( cx )))mm + 3mm}, {-((( cy )))mm - 3.5mm})
    {\fontsize{9}{11}\selectfont\bfseries\color{caiblu}\truncate{29mm}{((( cella.tappa.ref )))}};
  ((* endif *))
  ((* endfor *))
\end{tikzpicture}
((* endfor *))

%% ── PAGINE NOTE (riempimento fino a multiplo di 4) ──────────
((* for _ in range(pagine_note) *))
\newpage
\begin{tikzpicture}[remember picture, overlay, shift={(current page.north west)}]
  \pageheader{Note}
  \foreach \i in {1,...,14} {
    \draw[grigiolinea, line width=0.3pt]
      (6mm, -14mm - 8mm - \i*8mm) -- (99mm, -14mm - 8mm - \i*8mm);
  }
\end{tikzpicture}
((* endfor *))

\end{document}
